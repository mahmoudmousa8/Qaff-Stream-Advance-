// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model StreamSlot {
  id              String   @id @default(cuid())
  slotIndex       Int      @unique
  channelName     String   @default("")
  outputType      String   @default("youtube")
  streamKey       String   @default("")
  rtmpServer      String   @default("rtmp://a.rtmp.youtube.com/live2")
  filePath        String   @default("")
  inputType       String   @default("file") // "file" or "live"
  liveInputUrl    String   @default("")
  schedStart      String   @default("")
  schedStop       String   @default("")
  daily           Boolean  @default(false)
  weekly          Boolean  @default(false)
  isScheduled     Boolean  @default(false)
  manuallyStopped Boolean  @default(true)
  nextRunTime     String   @default("")
  status          String   @default("Stopped")
  isRunning       Boolean  @default(false)
  muteAudio       Boolean  @default(false)
  audioVolume     Float    @default(1.0)
  audioFilePath   String   @default("")
  overlayText     String   @default("")
  overlayTextRight String   @default("")
  overlayTextLeft  String   @default("")
  overlayTextEnabled Boolean @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model SystemLog {
  id        String   @id @default(cuid())
  message   String
  timestamp DateTime @default(now())
}

model AppSettings {
  id          String  @id @default(cuid())
  autoSave    Boolean @default(true)
  slotsCount  Int     @default(50)
}

model User {
  id          Int      @id @default(autoincrement())
  username    String   @unique // 'admin' or 'user'
  password    String   // Stored in plain text for the user so Admin can view it, as requested
  role        String   // 'admin' or 'user'
  slotsLimit  Int      @default(50)
  renewalDate String   @default("") // E.g., "2026-12-31"
  securityKey String   @default("") // E.g., client's security token for RTMP streaming
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
